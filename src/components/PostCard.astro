---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  image?: { src: string; alt: string };
}

const { title, description, pubDate, tags, slug, image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const truncated = description.length > 110
  ? description.slice(0, 110) + '…'
  : description;
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="post-card-image-link">
    <div class="post-card-image">
      {image
        ? <img src={image.src} alt={image.alt} loading="lazy" />
        : <div class="post-card-image-placeholder">▶</div>
      }
    </div>
  </a>
  <div class="post-card-body">
    <p class="meta">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    </p>
    <h2><a href={`/blog/${slug}`}>{title}</a></h2>
    <p class="description">{truncated}</p>
    {tags.length > 0 && (
      <div class="tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
  </div>
</article>

<style>
  .post-card-image-link {
    display: block;
    text-decoration: none;
  }
</style>
