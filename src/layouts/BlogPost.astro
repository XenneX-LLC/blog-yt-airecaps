---
import Base from './Base.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  image?: { src: string; alt: string };
  canonicalURL?: string;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
  rawContent?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  tags,
  image,
  canonicalURL,
  headings,
  prevPost,
  nextPost,
  rawContent = '',
} = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const wordCount = rawContent ? rawContent.split(/\s+/).filter(Boolean).length : 0;
const readingTime = wordCount > 0 ? Math.ceil(wordCount / 200) : null;
---

<Base
  title={title}
  description={description}
  image={image?.src}
  canonicalURL={canonicalURL}
  pubDate={pubDate}
  updatedDate={updatedDate}
  type="article"
>
  <div class="article-wrap">
    <div class="back-link-wrap">
      <a href="/blog/" class="back-link">← Back to Blog</a>
    </div>

    <article>
      {image && (
        <img
          src={image.src}
          alt={image.alt}
          class="article-hero-image"
        />
      )}

      <h1>{title}</h1>

      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        {updatedDate && (
          <span>Updated: <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time></span>
        )}
        <span>{author}</span>
        {readingTime && <span class="reading-time">{readingTime} min read</span>}
      </div>

      {tags.length > 0 && (
        <div class="tags" style="margin-bottom: 1.5rem;">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}

      <div class="article-divider"></div>

      <TableOfContents headings={headings} />

      <div class="content">
        <slot />
      </div>
    </article>

    {(prevPost || nextPost) && (
      <nav class="post-nav">
        <div class="post-nav-inner">
          {prevPost ? (
            <a href={`/blog/blog/${prevPost.slug}/`} class="post-nav-link post-nav-prev">
              <span class="post-nav-label">← Previous</span>
              <span class="post-nav-title">{prevPost.title}</span>
            </a>
          ) : <span />}
          {nextPost ? (
            <a href={`/blog/blog/${nextPost.slug}/`} class="post-nav-link post-nav-next">
              <span class="post-nav-label">Next →</span>
              <span class="post-nav-title">{nextPost.title}</span>
            </a>
          ) : <span />}
        </div>
      </nav>
    )}
  </div>
</Base>
