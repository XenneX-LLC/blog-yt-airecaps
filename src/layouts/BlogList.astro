---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  pageTitle: string;
  pageSubtitle?: string;
}

const { title, description, pageTitle, pageSubtitle } = Astro.props;
---

<Base title={title} description={description}>
  <div class="blog-hero">
    <h1><span class="gradient-text">AI Recaps</span> Blog</h1>
    {pageSubtitle && <p>{pageSubtitle}</p>}
  </div>
  <div class="posts-section">
    <div class="posts-grid">
      <slot />
    </div>
  </div>
</Base>
